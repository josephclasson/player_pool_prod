# Supabase: use hosted project **player_pool_dev** for local work (keys in .env.development.local or .env.local).
# Use **player_pool_prod** for production deploys and for .env.production.local when testing a production build locally.
# The Supabase CLI needs each project’s **reference id** (Project Settings → General), not the display name.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for commissioner "invite owners" redirectTo (magic link → /join) and similar. In production set this
# to your public site origin (no trailing slash). Also add each callback URL to Supabase → Authentication →
# URL Configuration → Redirect URLs, e.g.:
#   http://localhost:3000/auth/confirm
#   http://localhost:3000/join
#   https://your-domain.com/auth/confirm
#   https://your-domain.com/join
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# 6-digit PIN: in Supabase → Authentication → Providers → Email, set "Minimum password length" to 6 (default)
# or lower if you allow shorter PINs. Customize the invite email to show league code: {{ .Data.league_code }}

NEXT_PUBLIC_APP_NAME=Player Pool
NEXT_PUBLIC_DEFAULT_SEASON_YEAR=2026

# Tournament player import uses ESPN’s public college basketball APIs (no key). Throttled on the server.

# First Round (round of 64) Thursday, YYYY-MM-DD — used by Commissioner "Sync tournament window".
# Optional if the year is listed in lib/ncaa-tournament-calendar.ts.
# TOURNAMENT_FIRST_ROUND_THURSDAY_2026=2026-03-19

# Local dev: skip commissioner route auth (do not use in production).
ALLOW_COMMISSIONER_ROUTES_WITHOUT_AUTH=true

# Optional: mirror the flag above so the Commissioner Tools UI enables buttons without pasting the password locally.
# NEXT_PUBLIC_ALLOW_COMMISSIONER_ROUTES_WITHOUT_AUTH=true

# Commissioner password (required in production for admin APIs). Users enter it under "Act as commissioner"
# in the app header; it is sent as header x-player-pool-commissioner-secret.
# COMMISSIONER_API_SECRET=your-strong-shared-secret

# Optional: force leagues.owner_id to this Auth user UUID (sign up once, copy from Dashboard → Authentication).
# If unset, create-league with commissioner password auto-creates pool-league-owner@player-pool.internal (or email below).
# COMMISSIONER_LEAGUE_OWNER_USER_ID=00000000-0000-4000-8000-000000000000

# Optional: email for that auto-provisioned commissioner-password user (default pool-league-owner@player-pool.internal).
# COMMISSIONER_LEAGUE_OWNER_EMAIL=you@example.com

